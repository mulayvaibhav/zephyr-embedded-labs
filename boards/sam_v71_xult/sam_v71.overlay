/ {
    my_outputs {
        compatible = "gpio-leds";

        pa06_out: pa06_out {
            gpios = <&pioa 6 GPIO_ACTIVE_HIGH>;
            label = "PA06 Output";
        };
    };

    aliases {
        pa06-out = &pa06_out;
    };

};

&usart0 {
    status = "okay";
    current-speed = <9600>;
    pinctrl-0 = <&usart0_default>;
    pinctrl-names = "default";
};